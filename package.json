{
  "name": "tg-gf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/desktop",
    "apps/mobile"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --host",
    "dev:api": "npm run dev --workspace @tg-gf/api",
    "dev:desktop": "npm run build:web && npm run build:api && npm run build:desktop && npm run start --workspace @tg-gf/desktop",
    "build": "npm run build:web",
    "build:web": "tsc && vite build && node scripts/copy-runtime-artifacts-to-dist.mjs",
    "build:api": "npm run build --workspace @tg-gf/api",
    "build:desktop": "npm run build --workspace @tg-gf/desktop",
    "pack:desktop": "npm install --include=dev && npm run build:web && npm run build:api && npm run pack --workspace @tg-gf/desktop",
    "dist:desktop": "npm install --include=dev && npm run build:web && npm run build:api && npm run dist --workspace @tg-gf/desktop",
    "build:mobile": "npm run build --workspace @tg-gf/mobile",
    "sync:android": "npm run sync:android --workspace @tg-gf/mobile",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "npm run test --workspace @tg-gf/api",
    "test:desktop": "npm run test --workspace @tg-gf/desktop",
    "test:mobile": "npm run test --workspace @tg-gf/mobile"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
